# ============================================================
# spreadBot Configuration — copy to .env and fill in values
# ============================================================

# ----- Mode -----
# Options: collect | paper | backtest | live
BOT_MODE=paper

# ----- Binance -----
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Fee tier: 0.001 = 0.1% (standard), 0.00075 = 0.075% (BNB discount)
BINANCE_TAKER_FEE=0.001

# ----- DEX RPC Endpoints (WebSocket) -----
# Get free keys from alchemy.com or infura.io
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_WS_URL=wss://bsc-mainnet.nodereal.io/ws/v1/YOUR_KEY
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ----- Wallet (for live trading only) -----
PRIVATE_KEY=

# ----- Strategy -----
# Minimum net profit % to trigger a trade (after all fees)
MIN_PROFIT_PCT=0.005
# Maximum position size in USD per trade
MAX_POSITION_USD=500.0
# Minimum 24h DEX pool volume to consider a pool (USD)
MIN_POOL_VOLUME_USD=100000.0
# Number of top alt pairs to track
TOP_N_PAIRS=20

# ----- Backtest -----
BACKTEST_START=2025-01-01
BACKTEST_END=2025-02-01
# Comma-separated thresholds for param sweep
SWEEP_THRESHOLDS=0.001,0.0025,0.005,0.01,0.02

# ----- Database -----
DB_PATH=./spreadbot.db

# ----- Logging -----
LOG_LEVEL=INFO
LOG_JSON=false
